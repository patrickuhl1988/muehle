    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "generate-assets": "node scripts/generate-assets.js",
